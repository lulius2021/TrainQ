VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Service role key is required for API routes (Server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Garmin Integration (Supabase Edge Functions)
GARMIN_CONSUMER_KEY=your_garmin_consumer_key
GARMIN_CONSUMER_SECRET=your_garmin_consumer_secret
GARMIN_CALLBACK_URL=https://your-project.supabase.co/functions/v1/garmin-auth-callback
